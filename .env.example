# Copy this file to .env and fill in ONE provider's key.
#
# Recommended: Groq (free + fast). Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback: Google Gemini. Get a key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Optional: force a provider ("groq" or "gemini"). Auto-detected if unset.
# LLM_PROVIDER=groq
