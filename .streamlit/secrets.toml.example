# For local use: copy to .streamlit/secrets.toml (git-ignored).
# For Streamlit Community Cloud: paste these into the app's
# "Settings -> Secrets" box in the dashboard.

# Recommended: Groq (free + fast) -> https://console.groq.com/keys
GROQ_API_KEY = "your_groq_key_here"
GROQ_MODEL = "llama-3.3-70b-versatile"

# Optional fallback (used only if no Groq key is set):
# GEMINI_API_KEY = "your_gemini_key_here"
# GEMINI_MODEL = "gemini-2.0-flash"
